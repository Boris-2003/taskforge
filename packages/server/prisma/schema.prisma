// Prisma Schema：定义数据库连接和数据模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // 从 .env 文件读取连接字符串
}

model Task {
  // 主键：字符串类型，自动生成 UUID
  id          String   @id @default(uuid())

  // 任务标题，必填
  title       String

  // 任务描述，默认空字符串
  description String   @default("")

  // 任务状态：todo | in-progress | done，默认 todo
  status      String   @default("todo")

  // 创建时间，插入时自动设置为当前时间
  createdAt   DateTime @default(now())

  // 更新时间，每次 update 时自动刷新
  updatedAt   DateTime @updatedAt
}
